direction: right

title: Web Crawler — Distributed Architecture {
  near: top-center
  shape: text
  style.font-size: 22
  style.bold: true
}

# ─── Data Server ──────────────────────────────────────────────────────────────

data_server: Data Server {
  shape: rectangle
  style.fill: "#dbeafe"
  style.stroke: "#2563eb"
  style.stroke-width: 2

  datasource: pages.csv {
    shape: cylinder
    style.fill: "#bfdbfe"
    label: "pages.csv\nID;TEXT;LINKS"
  }

  url_map: "Map<String, List<String>>" {
    shape: rectangle
    style.fill: "#eff6ff"
    label: "Map<String, List<String>>\n(loaded at startup)"
  }

  server_socket: ServerSocket {
    shape: rectangle
    style.fill: "#eff6ff"
    label: "ServerSocket\n(fixed port)"
  }

  executor: ExecutorService {
    shape: rectangle
    style.fill: "#eff6ff"
    label: "ExecutorService\n(1 thread / connection)"
  }

  datasource -> url_map: load into memory
  server_socket -> executor: accept & dispatch
  url_map -> executor: lookup links
}

# ─── Coordinator ──────────────────────────────────────────────────────────────

coordinator: Coordinator (Master) {
  shape: rectangle
  style.fill: "#dcfce7"
  style.stroke: "#16a34a"
  style.stroke-width: 2

  seeds: "Seed URLs (initial list)" {
    shape: page
    style.fill: "#f0fdf4"
  }

  queue: "BlockingQueue<String>" {
    shape: queue
    style.fill: "#f0fdf4"
    label: "BlockingQueue<String>\n(URLs pending crawl)"
  }

  visited: ConcurrentHashMap {
    shape: rectangle
    style.fill: "#f0fdf4"
    label: "ConcurrentHashMap\n(visited URL set)"
  }

  server_socket: ServerSocket {
    shape: rectangle
    style.fill: "#f0fdf4"
    label: "ServerSocket\n(Worker connections)"
  }

  dispatcher: Dispatcher Thread {
    shape: rectangle
    style.fill: "#bbf7d0"
    label: "Dispatcher Thread\n(assigns URLs to idle Workers)"
  }

  seeds -> queue: enqueue seeds
  queue -> dispatcher: poll next URL
  dispatcher -> visited: check & mark visited
  server_socket -> dispatcher: "IDLE / FOUND signals"
  server_socket -> queue: "enqueue new URLs\n(dedup via visited map)"
}

# ─── Workers ──────────────────────────────────────────────────────────────────

workers: Workers {
  shape: rectangle
  style.fill: "#fef9c3"
  style.stroke: "#ca8a04"
  style.stroke-width: 2

  worker1: Worker 1 {
    shape: rectangle
    style.fill: "#fefce8"

    coord_sock1: "Socket (Coordinator)" {
      shape: rectangle
      style.fill: "#fde68a"
      label: "Socket\n(Coordinator)"
    }
    data_sock1: "Socket (Data Server)" {
      shape: rectangle
      style.fill: "#fde68a"
      label: "Socket\n(Data Server)"
    }
    pool1: ExecutorService {
      shape: rectangle
      style.fill: "#fffbeb"
      label: "ExecutorService\n(thread pool)"
    }
    proc1: Processing Pipeline {
      shape: rectangle
      style.fill: "#fffbeb"
      label: "Processing Pipeline\n1. integrity validation\n2. filter self-references\n3. categorize (Predicate<String>)"
    }

    coord_sock1 -> pool1: "receive URL task"
    pool1 -> data_sock1: "GET /url HTTP/1.1"
    data_sock1 -> pool1: "LINKS: ..."
    pool1 -> proc1: raw links
    proc1 -> coord_sock1: "FOUND / IDLE"
  }

  workerN: Worker N {
    shape: rectangle
    style.fill: "#fefce8"
    style.stroke-dash: 4

    coord_sockN: "Socket (Coordinator)" {
      shape: rectangle
      style.fill: "#fde68a"
      label: "Socket\n(Coordinator)"
    }
    data_sockN: "Socket (Data Server)" {
      shape: rectangle
      style.fill: "#fde68a"
      label: "Socket\n(Data Server)"
    }
    poolN: ExecutorService {
      shape: rectangle
      style.fill: "#fffbeb"
      label: "ExecutorService\n(thread pool)"
    }
    procN: Processing Pipeline {
      shape: rectangle
      style.fill: "#fffbeb"
      label: "Processing Pipeline\n1. integrity validation\n2. filter self-references\n3. categorize (Predicate<String>)"
    }

    coord_sockN -> poolN: "receive URL task"
    poolN -> data_sockN: "GET /url HTTP/1.1"
    data_sockN -> poolN: "LINKS: ..."
    poolN -> procN: raw links
    procN -> coord_sockN: "FOUND / IDLE"
  }
}

# ─── Cross-component flows ─────────────────────────────────────────────────────

# 1. Workers register with Coordinator on startup
workers.worker1.coord_sock1 -> coordinator.server_socket: "REGISTER (thread capacity)" {
  style.stroke: "#6b7280"
  style.stroke-dash: 4
}
workers.workerN.coord_sockN -> coordinator.server_socket: "REGISTER (thread capacity)" {
  style.stroke: "#6b7280"
  style.stroke-dash: 4
}

# 2. Coordinator dispatches URL tasks to Workers
coordinator.dispatcher -> workers.worker1.coord_sock1: "URL task (Socket)" {
  style.stroke: "#16a34a"
}
coordinator.dispatcher -> workers.workerN.coord_sockN: "URL task (Socket)" {
  style.stroke: "#16a34a"
}

# 3. Workers fetch links from Data Server
workers.worker1.data_sock1 -> data_server.server_socket: "GET /url HTTP/1.1" {
  style.stroke: "#2563eb"
}
workers.workerN.data_sockN -> data_server.server_socket: "GET /url HTTP/1.1" {
  style.stroke: "#2563eb"
}

# 4. Workers report results back to Coordinator
workers.worker1.coord_sock1 -> coordinator.server_socket: "FOUND: url1, url2 FROM src" {
  style.stroke: "#ca8a04"
}
workers.workerN.coord_sockN -> coordinator.server_socket: "FOUND: url1, url2 FROM src" {
  style.stroke: "#ca8a04"
}

# ─── Shutdown condition ────────────────────────────────────────────────────────

shutdown: Shutdown Condition {
  shape: rectangle
  style.fill: "#fce7f3"
  style.stroke: "#db2777"
  style.stroke-width: 2
  label: "Coordinator terminates when ALL hold:\n• BlockingQueue is empty\n• All Workers report IDLE\n• No FOUND messages in transit"
}

coordinator -> shutdown: monitors {
  style.stroke: "#db2777"
  style.stroke-dash: 4
}
