direction: right

title: Web Crawler - Infrastructure Diagram {
  near: top-center
  shape: text
  style.font-size: 22
  style.bold: true
}

clients: Execution Environment {
  shape: rectangle
  style.fill: "#f8fafc"
  style.stroke: "#94a3b8"
  style.stroke-width: 2

  coordinator_host: Coordinator Node {
    shape: rectangle
    style.fill: "#dcfce7"
    style.stroke: "#16a34a"
    style.stroke-width: 2
    label: "Coordinator Node\nMaster process"
  }

  worker_group: Worker Nodes {
    shape: rectangle
    style.fill: "#fef9c3"
    style.stroke: "#ca8a04"
    style.stroke-width: 2
    label: "Worker Nodes\n1..N worker processes"
  }

  data_host: Data Server Node {
    shape: rectangle
    style.fill: "#dbeafe"
    style.stroke: "#2563eb"
    style.stroke-width: 2
    label: "Data Server Node\nServes page/link data"
  }
}

storage: Shared Data Source {
  shape: cylinder
  style.fill: "#bfdbfe"
  style.stroke: "#2563eb"
  style.stroke-width: 2
  label: "pages.csv\nInput dataset"
}

coordinator_host -> worker_group: "Task dispatch + result reporting\nTCP sockets"
worker_group -> data_host: "Page/link fetch requests\nHTTP over TCP"
data_host -> storage: "Loads dataset at startup"

note: Infrastructure Scope {
  shape: rectangle
  style.fill: "#f8fafc"
  style.stroke: "#94a3b8"
  label: "Shows runtime nodes, data store, and network communication.\nOmits in-memory structures and thread-level internals."
}

note -> clients
